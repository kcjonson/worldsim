<?xml version="1.0" encoding="UTF-8"?>
<!-- Wood - Chopped from trees, primary construction material
     Unified entity: exists in world (when dropped) or inventory (when carried)
     Source: Harvested from Flora_TreeOak, Flora_TreeMaple
-->
<AssetDefinitions>
  <AssetDef>
    <defName>Wood</defName>
    <label>Wood</label>
    <assetType>simple</assetType>
    <svgPath>wood.svg</svgPath>
    <worldHeight>0.4</worldHeight>

    <rendering>
      <complexity>simple</complexity>
      <tier>instanced</tier>
    </rendering>

    <!-- Item category: raw construction material -->
    <category>RawMaterial</category>

    <!-- Bulk material: carried as a strength-limited armful in BOTH hands, never the backpack -->
    <handsRequired>2</handsRequired>

    <!-- Item properties (when in inventory) -->
    <item>
      <!-- NOT enforced at runtime yet: addItem caps at the inventory's maxStackSize.
           Item-driven stack size is a deferred follow-up. -->
      <stackSize>40</stackSize>
      <!-- A short log/billet; mass drives how much a colonist can haul per trip -->
      <mass>2.5</mass>
    </item>

    <!-- Entity capabilities. Carryable (without a quantity) keeps VisionSystem discovery;
         a loose ground pile's count lives in its per-entity ResourceStack, not here. -->
    <capabilities>
      <carryable/>
    </capabilities>

    <!-- No placement - wood doesn't spawn naturally, it's chopped from trees -->
  </AssetDef>
</AssetDefinitions>
