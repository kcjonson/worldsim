<?xml version="1.0" encoding="UTF-8"?>
<!-- Small Stone - Ground scatter that can be picked up
     Unified entity: exists in world (spawned) or inventory (carried)
     Future: crafting material (stone tools, construction)
-->
<AssetDefinitions>
  <AssetDef>
    <defName>SmallStone</defName>
    <label>Small Stone</label>
    <assetType>simple</assetType>
    <svgPath>small_stone.svg</svgPath>
    <worldHeight>0.15</worldHeight>

    <rendering>
      <complexity>simple</complexity>
      <tier>instanced</tier>
    </rendering>

    <!-- No animation - stones don't sway -->

    <!-- Item category: raw crafting material -->
    <category>RawMaterial</category>

    <!-- Item properties (when in inventory) -->
    <item>
      <stackSize>10</stackSize>
      <mass>1.5</mass>
      <!-- Not edible -->
    </item>

    <!-- Entity capabilities -->
    <capabilities>
      <carryable quantity="1"/>
    </capabilities>

    <!-- Per-biome placement configuration.
         Loose stone is near-universal: scattered wherever there's exposed ground, denser on
         rocky/dry/high terrain (deserts, montane, alpine, beaches), thinner under wet/forest
         cover, and barely present on polar ice. It's a basic early crafting material, so every
         land biome carries at least a little. -->
    <placement>
      <!-- Temperate -->
      <biome name="TemperateDeciduousForest">
        <spawnChance>0.015</spawnChance>
        <distribution>uniform</distribution>
      </biome>
      <biome name="TemperateRainforest">
        <spawnChance>0.012</spawnChance>
        <distribution>uniform</distribution>
      </biome>
      <biome name="TemperateGrassland">
        <spawnChance>0.02</spawnChance>
        <distribution>uniform</distribution>
      </biome>

      <!-- Boreal / montane / alpine: rocky, stone-rich -->
      <biome name="BorealForest">
        <spawnChance>0.018</spawnChance>
        <distribution>uniform</distribution>
      </biome>
      <biome name="MontaneForest">
        <spawnChance>0.035</spawnChance>
        <distribution>uniform</distribution>
      </biome>
      <biome name="AlpineGrassland">
        <spawnChance>0.035</spawnChance>
        <distribution>uniform</distribution>
      </biome>
      <biome name="AlpineTundra">
        <spawnChance>0.03</spawnChance>
        <distribution>uniform</distribution>
      </biome>

      <!-- Tropical -->
      <biome name="TropicalRainforest">
        <spawnChance>0.01</spawnChance>
        <distribution>uniform</distribution>
      </biome>
      <biome name="TropicalSeasonalForest">
        <spawnChance>0.012</spawnChance>
        <distribution>uniform</distribution>
      </biome>
      <biome name="TropicalSavanna">
        <spawnChance>0.018</spawnChance>
        <distribution>uniform</distribution>
      </biome>

      <!-- Dry: stony ground, abundant surface rock -->
      <biome name="HotDesert">
        <spawnChance>0.035</spawnChance>
        <distribution>uniform</distribution>
      </biome>
      <biome name="ColdDesert">
        <spawnChance>0.035</spawnChance>
        <distribution>uniform</distribution>
      </biome>
      <biome name="SemiDesert">
        <spawnChance>0.03</spawnChance>
        <distribution>uniform</distribution>
      </biome>
      <biome name="XericShrubland">
        <spawnChance>0.03</spawnChance>
        <distribution>uniform</distribution>
      </biome>

      <!-- Cold / polar: thin, mostly snow and ice -->
      <biome name="ArcticTundra">
        <spawnChance>0.012</spawnChance>
        <distribution>uniform</distribution>
      </biome>
      <biome name="PolarDesert">
        <spawnChance>0.005</spawnChance>
        <distribution>uniform</distribution>
      </biome>

      <!-- Wet ground holds fewer loose stones -->
      <biome name="TemperateWetland">
        <spawnChance>0.008</spawnChance>
        <distribution>uniform</distribution>
      </biome>
      <biome name="TropicalWetland">
        <spawnChance>0.008</spawnChance>
        <distribution>uniform</distribution>
      </biome>

      <!-- Beaches: pebbles and shingle -->
      <biome name="Beach">
        <spawnChance>0.03</spawnChance>
        <distribution>uniform</distribution>
      </biome>

      <!-- Groups this asset belongs to -->
      <groups>
        <group>ground_scatter</group>
        <group>stone_sources</group>
      </groups>

      <!-- Relationships with other entities -->
      <relationships>
        <!-- Stones avoid each other to prevent unnatural clustering -->
        <avoids type="same" distance="1.5" penalty="0.2"/>
        <!-- Stones don't spawn under dense tree canopy -->
        <avoids group="trees" distance="2.0" penalty="0.4"/>
      </relationships>
    </placement>

    <!-- Multiple variants for visual variety -->
    <variantCount>4</variantCount>
  </AssetDef>
</AssetDefinitions>
