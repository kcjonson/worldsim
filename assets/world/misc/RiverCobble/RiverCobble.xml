<?xml version="1.0" encoding="UTF-8"?>
<!-- River Cobble - Cluster of smooth rounded river pebbles.
     Found on beaches and wetland margins; yields SmallStone when gathered. -->
<AssetDefinitions>
  <AssetDef>
    <defName>RiverCobble</defName>
    <label>River Cobble</label>
    <assetType>simple</assetType>
    <svgPath>river_cobble.svg</svgPath>
    <worldHeight>0.2</worldHeight>
    <!-- Ground scatter: no canonical orientation, so randomize placement angle. -->
    <randomRotation>180</randomRotation>

    <rendering>
      <complexity>simple</complexity>
      <tier>instanced</tier>
    </rendering>

    <capabilities>
      <harvestable yield="SmallStone" amountMin="2" amountMax="3" durability="30" destructive="true"/>
    </capabilities>

    <placement>
      <biome name="Beach">
        <spawnChance>0.03</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>2,5</clumpSize>
          <clumpRadius>1.5,3.0</clumpRadius>
          <clumpSpacing>8.0,16.0</clumpSpacing>
        </clumping>
      </biome>
      <biome name="TemperateWetland">
        <spawnChance>0.015</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>1,3</clumpSize>
          <clumpRadius>1.0,2.5</clumpRadius>
          <clumpSpacing>10.0,20.0</clumpSpacing>
        </clumping>
      </biome>
      <biome name="TropicalWetland">
        <spawnChance>0.012</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>1,3</clumpSize>
          <clumpRadius>1.0,2.5</clumpRadius>
          <clumpSpacing>10.0,20.0</clumpSpacing>
        </clumping>
      </biome>

      <groups>
        <group>ground_scatter</group>
        <group>stone_sources</group>
      </groups>

      <relationships>
        <avoids type="same" distance="2.0" penalty="0.3"/>
      </relationships>
    </placement>

    <variantCount>1</variantCount>
  </AssetDef>
</AssetDefinitions>
