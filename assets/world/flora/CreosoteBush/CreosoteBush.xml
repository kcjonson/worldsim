<?xml version="1.0" encoding="UTF-8"?>
<!-- Creosote Bush Asset Definition
     Iconic desert shrub of the Mojave/Sonoran/Chihuahuan. Sparse, open form with
     wiry branches and tiny dark olive-green leaves. Slow-growing; harvested for sticks.
-->
<AssetDefinitions>
  <AssetDef>
    <defName>Flora_CreosoteBush</defName>
    <label>Creosote Bush</label>
    <assetType>simple</assetType>
    <svgPath>creosote_bush.svg</svgPath>
    <worldHeight>0.7</worldHeight>

    <rendering>
      <complexity>simple</complexity>
      <tier>instanced</tier>
    </rendering>

    <animation>
      <type>parametric</type>
      <windResponse>0.3</windResponse>
      <swayFrequency>0.3,0.6</swayFrequency>
    </animation>

    <!-- Harvested for sticks; non-destructive with a small resource pool -->
    <capabilities>
      <harvestable yield="Stick" amountMin="1" amountMax="1" durability="40"
                   destructive="false" totalResourceMin="3" totalResourceMax="5"/>
    </capabilities>

    <placement>
      <biome name="HotDesert">
        <spawnChance>0.012</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>1,3</clumpSize>
          <clumpRadius>1.0,2.5</clumpRadius>
          <clumpSpacing>12.0,22.0</clumpSpacing>
        </clumping>
      </biome>
      <biome name="SemiDesert">
        <spawnChance>0.008</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>1,3</clumpSize>
          <clumpRadius>1.0,2.0</clumpRadius>
          <clumpSpacing>14.0,25.0</clumpSpacing>
        </clumping>
      </biome>

      <groups>
        <group>bushes</group>
        <group>wood_sources</group>
        <group>small_flora</group>
      </groups>

      <relationships>
        <avoids type="same" distance="2.0" penalty="0.3"/>
      </relationships>
    </placement>

    <variantCount>1</variantCount>
  </AssetDef>
</AssetDefinitions>
