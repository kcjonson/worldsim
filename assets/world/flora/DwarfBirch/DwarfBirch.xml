<?xml version="1.0" encoding="UTF-8"?>
<!-- DwarfBirch - Low ground-hugging arctic/alpine birch scrub.
     Tangled wiry brown twigs with small round green leaves; harvested for sticks. -->
<AssetDefinitions>
  <AssetDef>
    <defName>Flora_DwarfBirch</defName>
    <label>Dwarf Birch</label>
    <assetType>simple</assetType>
    <svgPath>dwarf_birch.svg</svgPath>
    <worldHeight>0.4</worldHeight>

    <rendering>
      <complexity>simple</complexity>
      <tier>instanced</tier>
    </rendering>

    <animation>
      <type>parametric</type>
      <windResponse>0.2</windResponse>
      <swayFrequency>0.3,0.6</swayFrequency>
    </animation>

    <capabilities>
      <harvestable yield="Stick" amountMin="1" amountMax="1" duration="4.0"
                   destructive="false" totalResourceMin="3" totalResourceMax="5"/>
