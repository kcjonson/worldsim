<?xml version="1.0" encoding="UTF-8"?>
<!-- Dwarf Conifer - Small spruce/fir sapling in boreal and montane zones.
     Harvested for sticks (small branches and branchlets). Non-destructive with a resource pool. -->
<AssetDefinitions>
  <AssetDef>
    <defName>Flora_DwarfConifer</defName>
    <label>Dwarf Conifer</label>
    <assetType>simple</assetType>
    <svgPath>dwarf_conifer.svg</svgPath>
    <worldHeight>0.8</worldHeight>

    <rendering>
      <complexity>simple</complexity>
      <tier>instanced</tier>
    </rendering>

    <animation>
      <type>parametric</type>
      <windResponse>0.15</windResponse>
      <swayFrequency>0.3,0.6</swayFrequency>
    </animation>

    <!-- Entity capabilities - snapped branches for sticks, tree remains -->
    <capabilities>
      <harvestable yield="Stick" amountMin="1" amountMax="1" durability="40"
                   destructive="false" totalResourceMin="3" totalResourceMax="5"/>
    </capabilities>

    <!-- Per-biome placement: boreal and montane forest understory/clearings -->
    <placement>
      <biome name="BorealForest">
        <spawnChance>0.02</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>1,3</clumpSize>
          <clumpRadius>0.8,1.5</clumpRadius>
          <clumpSpacing>10.0,18.0</clumpSpacing>
        </clumping>
      </biome>
      <biome name="MontaneForest">
        <spawnChance>0.016</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>1,2</clumpSize>
          <clumpRadius>0.6,1.2</clumpRadius>
          <clumpSpacing>12.0,20.0</clumpSpacing>
        </clumping>
      </biome>

      <groups>
        <group>bushes</group>
        <group>wood_sources</group>
        <group>small_flora</group>
      </groups>

      <relationships>
        <avoids type="same" distance="2.0" penalty="0.3"/>
      </relationships>
    </placement>

    <variantCount>1</variantCount>
  </AssetDef>
</AssetDefinitions>
