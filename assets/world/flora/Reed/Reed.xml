<?xml version="1.0" encoding="UTF-8"?>
<!-- Reed (Cattail) Asset Definition
     Wetland plant that grows near water in clumps.
     Harvested for plant fiber (crafting material).
-->
<AssetDefinitions>
  <AssetDef>
    <defName>Flora_Reed</defName>
    <label>Reed</label>
    <assetType>simple</assetType>
    <svgPath>reed.svg</svgPath>
    <worldHeight>1.0</worldHeight>

    <rendering>
      <complexity>simple</complexity>
      <tier>instanced</tier>
    </rendering>

    <animation>
      <type>parametric</type>
      <windResponse>0.5</windResponse>
      <swayFrequency>0.3,0.6</swayFrequency>
    </animation>

    <!-- Entity capabilities - harvested for plant fiber (destructive) -->
    <capabilities>
      <harvestable yield="PlantFiber" amountMin="1" amountMax="3" duration="2.0" destructive="true"/>
    </capabilities>

    <!-- Per-biome placement configuration.
         Reeds are the PlantFiber source and grow at the water's edge in essentially any
         non-frozen biome (all blocks keep near="Water"): dense in wetlands, moderate at
         grassland/savanna/shrubland ponds and desert oases, sparse along forest streams and
         brackish beaches. Absent only where surface water is frozen (tundra/polar). This keeps
         fiber - and so early tools like the axe - reachable wherever a colony lands near water. -->
    <placement>
      <!-- Wetlands: dense stands -->
      <biome name="TemperateWetland" near="Water" distance="3">
        <spawnChance>0.30</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>8,16</clumpSize>
          <clumpRadius>1.0,2.0</clumpRadius>
          <clumpSpacing>6.0,12.0</clumpSpacing>
        </clumping>
      </biome>
      <biome name="TropicalWetland" near="Water" distance="3">
        <spawnChance>0.25</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>8,16</clumpSize>
          <clumpRadius>1.0,2.0</clumpRadius>
          <clumpSpacing>6.0,12.0</clumpSpacing>
        </clumping>
      </biome>

      <!-- Grassland / savanna / shrubland ponds: moderate patches -->
      <biome name="TemperateGrassland" near="Water" distance="3">
        <spawnChance>0.15</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>5,10</clumpSize>
          <clumpRadius>0.8,1.5</clumpRadius>
          <clumpSpacing>8.0,15.0</clumpSpacing>
        </clumping>
      </biome>
      <biome name="TropicalSavanna" near="Water" distance="3">
        <spawnChance>0.12</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>5,10</clumpSize>
          <clumpRadius>0.8,1.5</clumpRadius>
          <clumpSpacing>8.0,15.0</clumpSpacing>
        </clumping>
      </biome>
      <biome name="XericShrubland" near="Water" distance="3">
        <spawnChance>0.15</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>5,10</clumpSize>
          <clumpRadius>0.8,1.5</clumpRadius>
          <clumpSpacing>8.0,15.0</clumpSpacing>
        </clumping>
      </biome>
      <biome name="AlpineGrassland" near="Water" distance="3">
        <spawnChance>0.06</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>3,6</clumpSize>
          <clumpRadius>0.5,1.0</clumpRadius>
          <clumpSpacing>12.0,20.0</clumpSpacing>
        </clumping>
      </biome>

      <!-- Desert oases: small but reliable stands at the water -->
      <biome name="SemiDesert" near="Water" distance="3">
        <spawnChance>0.12</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>4,8</clumpSize>
          <clumpRadius>0.8,1.5</clumpRadius>
          <clumpSpacing>8.0,15.0</clumpSpacing>
        </clumping>
      </biome>
      <biome name="HotDesert" near="Water" distance="3">
        <spawnChance>0.10</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>4,8</clumpSize>
          <clumpRadius>0.8,1.5</clumpRadius>
          <clumpSpacing>8.0,15.0</clumpSpacing>
        </clumping>
      </biome>
      <biome name="ColdDesert" near="Water" distance="3">
        <spawnChance>0.06</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>3,6</clumpSize>
          <clumpRadius>0.5,1.0</clumpRadius>
          <clumpSpacing>12.0,20.0</clumpSpacing>
        </clumping>
      </biome>

      <!-- Forest streams and brackish beaches: sparse patches -->
      <biome name="TemperateDeciduousForest" near="Water" distance="3">
        <spawnChance>0.08</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>3,6</clumpSize>
          <clumpRadius>0.5,1.0</clumpRadius>
          <clumpSpacing>12.0,20.0</clumpSpacing>
        </clumping>
      </biome>
      <biome name="TemperateRainforest" near="Water" distance="3">
        <spawnChance>0.10</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>3,6</clumpSize>
          <clumpRadius>0.5,1.0</clumpRadius>
          <clumpSpacing>12.0,20.0</clumpSpacing>
        </clumping>
      </biome>
      <biome name="BorealForest" near="Water" distance="3">
        <spawnChance>0.08</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>3,6</clumpSize>
          <clumpRadius>0.5,1.0</clumpRadius>
          <clumpSpacing>12.0,20.0</clumpSpacing>
        </clumping>
      </biome>
      <biome name="MontaneForest" near="Water" distance="3">
        <spawnChance>0.05</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>3,6</clumpSize>
          <clumpRadius>0.5,1.0</clumpRadius>
          <clumpSpacing>12.0,20.0</clumpSpacing>
        </clumping>
      </biome>
      <biome name="TropicalSeasonalForest" near="Water" distance="3">
        <spawnChance>0.08</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>3,6</clumpSize>
          <clumpRadius>0.5,1.0</clumpRadius>
          <clumpSpacing>12.0,20.0</clumpSpacing>
        </clumping>
      </biome>
      <biome name="TropicalRainforest" near="Water" distance="3">
        <spawnChance>0.06</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>3,6</clumpSize>
          <clumpRadius>0.5,1.0</clumpRadius>
          <clumpSpacing>12.0,20.0</clumpSpacing>
        </clumping>
      </biome>
      <biome name="Beach" near="Water" distance="3">
        <spawnChance>0.08</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>3,6</clumpSize>
          <clumpRadius>0.5,1.0</clumpRadius>
          <clumpSpacing>12.0,20.0</clumpSpacing>
        </clumping>
      </biome>
      <!-- ArcticTundra, AlpineTundra, PolarDesert omitted: surface water is frozen -->

      <!-- Groups this asset belongs to -->
      <groups>
        <group>water_plants</group>
        <group>fiber_sources</group>
        <group>small_flora</group>
      </groups>

      <!-- Relationships with other entities -->
      <relationships>
        <!-- Reeds cluster together naturally (form stands) -->
        <affinity type="same" distance="3.0" strength="1.5"/>
        <!-- Avoid spawning under trees -->
        <avoids group="trees" distance="3.0" penalty="0.3"/>
      </relationships>
    </placement>

    <variantCount>3</variantCount>
  </AssetDef>
</AssetDefinitions>
