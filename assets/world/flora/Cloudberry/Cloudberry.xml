<?xml version="1.0" encoding="UTF-8"?>
<!-- Cloudberry - Low tundra/wetland berry plant with lobed leaves and a single amber drupe.
     Non-destructive harvest with regrowth; a rare arctic food source. -->
<AssetDefinitions>
  <AssetDef>
    <defName>Flora_Cloudberry</defName>
    <label>Cloudberry</label>
    <assetType>simple</assetType>
    <svgPath>cloudberry.svg</svgPath>
    <worldHeight>0.2</worldHeight>

    <rendering>
      <complexity>simple</complexity>
      <tier>instanced</tier>
    </rendering>

    <animation>
      <type>parametric</type>
      <windResponse>0.15</windResponse>
      <swayFrequency>0.3,0.6</swayFrequency>
    </animation>

    <capabilities>
      <harvestable yield="Berry" amountMin="2" amountMax="5" duration="2.0"
                   destructive="false" regrowthTime="60.0"/>
    </capabilities>

    <placement>
      <biome name="TemperateWetland">
        <spawnChance>0.015</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>2,5</clumpSize>
          <clumpRadius>1.0,2.0</clumpRadius>
          <clumpSpacing>10.0,18.0</clumpSpacing>
        </clumping>
      </biome>
      <biome name="ArcticTundra">
        <spawnChance>0.012</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>2,5</clumpSize>
          <clumpRadius>1.0,2.0</clumpRadius>
          <clumpSpacing>12.0,22.0</clumpSpacing>
        </clumping>
      </biome>

      <groups>
        <group>bushes</group>
        <group>food_sources</group>
        <group>small_flora</group>
      </groups>

      <relationships>
        <avoids type="same" distance="2.0" penalty="0.3"/>
      </relationships>
    </placement>

    <variantCount>1</variantCount>
  </AssetDef>
</AssetDefinitions>
