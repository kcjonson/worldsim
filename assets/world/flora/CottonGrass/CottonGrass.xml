<?xml version="1.0" encoding="UTF-8"?>
<!-- CottonGrass - Arctic/wetland sedge tuft with distinctive fluffy white seed heads.
     Destructive harvest for plant fiber; grows in tundra bogs and alpine wetlands. -->
<AssetDefinitions>
  <AssetDef>
    <defName>Flora_CottonGrass</defName>
    <label>Cotton Grass</label>
    <assetType>simple</assetType>
    <svgPath>cotton_grass.svg</svgPath>
    <worldHeight>0.4</worldHeight>

    <rendering>
      <complexity>simple</complexity>
      <tier>instanced</tier>
    </rendering>

    <animation>
      <type>parametric</type>
      <windResponse>0.45</windResponse>
      <swayFrequency>0.4,0.8</swayFrequency>
    </animation>

    <capabilities>
      <harvestable yield="PlantFiber" amountMin="1" amountMax="3" duration="2.0" destructive="true"/>
    </capabilities>

    <placement>
      <biome name="ArcticTundra">
        <spawnChance>0.015</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>3,8</clumpSize>
          <clumpRadius>1.0,2.5</clumpRadius>
          <clumpSpacing>8.0,16.0</clumpSpacing>
        </clumping>
      </biome>
      <biome name="AlpineTundra">
        <spawnChance>0.01</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>2,6</clumpSize>
          <clumpRadius>1.0,2.0</clumpRadius>
          <clumpSpacing>10.0,18.0</clumpSpacing>
        </clumping>
      </biome>
      <biome name="TemperateWetland">
        <spawnChance>0.012</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>3,8</clumpSize>
          <clumpRadius>1.0,2.5</clumpRadius>
          <clumpSpacing>8.0,16.0</clumpSpacing>
        </clumping>
      </biome>

      <groups>
        <group>fiber_sources</group>
        <group>small_flora</group>
      </groups>

      <relationships>
        <avoids type="same" distance="2.0" penalty="0.3"/>
      </relationships>
    </placement>

    <variantCount>1</variantCount>
  </AssetDef>
</AssetDefinitions>
