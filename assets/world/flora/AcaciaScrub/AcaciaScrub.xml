<?xml version="1.0" encoding="UTF-8"?>
<!-- Acacia Scrub - Flat-topped umbrella acacia of the tropical savanna.
     Iconic broad canopy seen from above; harvested for sticks. -->
<AssetDefinitions>
  <AssetDef>
    <defName>Flora_AcaciaScrub</defName>
    <label>Acacia Scrub</label>
    <assetType>simple</assetType>
    <svgPath>acacia_scrub.svg</svgPath>
    <worldHeight>1.0</worldHeight>

    <rendering>
      <complexity>simple</complexity>
      <tier>instanced</tier>
    </rendering>

    <animation>
      <type>parametric</type>
      <windResponse>0.15</windResponse>
      <swayFrequency>0.2,0.5</swayFrequency>
    </animation>

    <capabilities>
      <harvestable yield="Stick" amountMin="1" amountMax="1" duration="4.0"
                   destructive="false" totalResourceMin="3" totalResourceMax="5"/>
    </capabilities>

    <placement>
      <biome name="TropicalSavanna">
        <spawnChance>0.02</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>1,3</clumpSize>
          <clumpRadius>1.5,3.0</clumpRadius>
          <clumpSpacing>14.0,24.0</clumpSpacing>
        </clumping>
      </biome>

      <groups>
        <group>bushes</group>
        <group>wood_sources</group>
        <group>small_flora</group>
      </groups>

      <relationships>
        <avoids type="same" distance="2.0" penalty="0.3"/>
        <avoids group="trees" distance="3.0" penalty="0.5"/>
        <avoids group="food_sources" distance="2.0" penalty="0.5"/>
      </relationships>
    </placement>

    <variantCount>1</variantCount>
  </AssetDef>
</AssetDefinitions>
