<?xml version="1.0" encoding="UTF-8"?>
<!-- Tropical Berry - Leafy tropical fruit shrub with bright berry clusters.
     Non-destructive harvest; berries regrow after 60s. -->
<AssetDefinitions>
  <AssetDef>
    <defName>Flora_TropicalBerry</defName>
    <label>Tropical Berry</label>
    <assetType>simple</assetType>
    <svgPath>tropical_berry.svg</svgPath>
    <worldHeight>0.8</worldHeight>

    <rendering>
      <complexity>simple</complexity>
      <tier>instanced</tier>
    </rendering>

    <animation>
      <type>parametric</type>
      <windResponse>0.2</windResponse>
      <swayFrequency>0.3,0.6</swayFrequency>
    </animation>

    <capabilities>
      <harvestable yield="Berry" amountMin="2" amountMax="5" duration="2.0"
                   destructive="false" regrowthTime="60.0"/>
    </capabilities>

    <placement>
      <biome name="TropicalRainforest">
        <spawnChance>0.012</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>2,4</clumpSize>
          <clumpRadius>1.0,2.0</clumpRadius>
          <clumpSpacing>10.0,18.0</clumpSpacing>
        </clumping>
      </biome>
      <biome name="TropicalSeasonalForest">
        <spawnChance>0.012</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>2,4</clumpSize>
          <clumpRadius>1.0,2.0</clumpRadius>
          <clumpSpacing>10.0,18.0</clumpSpacing>
        </clumping>
      </biome>
      <biome name="TropicalSavanna">
        <spawnChance>0.01</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>2,4</clumpSize>
          <clumpRadius>1.0,2.0</clumpRadius>
          <clumpSpacing>12.0,22.0</clumpSpacing>
        </clumping>
      </biome>
      <biome name="TropicalWetland">
        <spawnChance>0.01</spawnChance>
        <distribution>clumped</distribution>
        <clumping>
          <clumpSize>2,4</clumpSize>
          <clumpRadius>1.0,2.0</clumpRadius>
          <clumpSpacing>12.0,20.0</clumpSpacing>
        </clumping>
      </biome>

      <groups>
        <group>bushes</group>
        <group>food_sources</group>
        <group>small_flora</group>
      </groups>

      <relationships>
        <avoids type="same" distance="2.0" penalty="0.3"/>
        <avoids group="trees" distance="2.0" penalty="0.3"/>
      </relationships>
    </placement>

    <variantCount>1</variantCount>
  </AssetDef>
</AssetDefinitions>
