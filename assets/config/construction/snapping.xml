<?xml version="1.0" encoding="UTF-8"?>
<!--
  Construction Snapping Configuration
  All distances in meters, angles in degrees.
  NO tiles anywhere in this file.

  NOTE: All values are starter estimates pending playtesting.
  Snap radii in particular depend on zoom range and feel; tune data-only here.
-->
<ConstructionSnapping>

  <!-- Angle snap increment. Segments snap to multiples of this relative to the
       previous segment (or world axes for the first segment).
       15 degrees gives 90/45/30/15 increments, which covers the common cases. -->
  <angleIncrementDegrees>15.0</angleIncrementDegrees>

  <!-- Snap radius for vertex-to-vertex snapping (cursor snaps to an existing
       vertex when within this distance). Generous: snapping is the expected mode. -->
  <vertexSnapRadiusMeters>0.4</vertexSnapRadiusMeters>

  <!-- Snap radius for cursor-to-edge snapping (T-junction on an existing segment). -->
  <edgeSnapRadiusMeters>0.3</edgeSnapRadiusMeters>

  <!-- Range at which smart guides are computed. Parallel/perpendicular hints are
       shown for existing edges within this distance of the cursor. -->
  <smartGuideRangeMeters>8.0</smartGuideRangeMeters>

  <!-- Cursor distance from the origin point at which the "click here to close"
       halo appears and snapping locks to the origin. Generous to make closing easy. -->
  <originCloseRadiusMeters>0.5</originCloseRadiusMeters>

</ConstructionSnapping>
