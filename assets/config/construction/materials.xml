<?xml version="1.0" encoding="UTF-8"?>
<!--
  Construction Materials Configuration
  Per-material properties for each structure kind.

  Units:
    costRatePerSquareMeter  - material items consumed per m² of foundation
    workRatePerSquareMeter  - work units per m² (drives build time)
    hp                      - hit points per m²
    flammability            - 0.0 (fireproof) to 1.0 (highly flammable)
    beauty                  - beauty contribution per m²
    speedModifier           - walking speed multiplier on the finished floor (1.0 = normal)

  Pattern block:
    emitter   - element emitter type name used by the renderer
    seed      - base seed for deterministic pattern generation
    color     - hex RGBA values for the material palette

  NOTE: All numeric values are starter estimates pending design tuning.
  Exact cost/work rates depend on the haul logistics decision (bulk containers,
  carry capacity) and playtesting. See open question #2 in building-construction.md.
-->
<ConstructionMaterials>

  <!-- Foundation materials -->
  <Foundation>

    <Material name="Wood">
      <!-- 1 plank per 0.5 m² is reasonable for a light floor deck -->
      <costRatePerSquareMeter>2.0</costRatePerSquareMeter>
      <!-- Moderate work: sill beams + joists + decking -->
      <workRatePerSquareMeter>12.0</workRatePerSquareMeter>
      <hp>40.0</hp>
      <flammability>0.8</flammability>
      <beauty>1.0</beauty>
      <!-- Planked floors are faster to walk on than bare ground -->
      <speedModifier>1.15</speedModifier>
      <pattern>
        <emitter>planks</emitter>
        <seed>1001</seed>
        <!-- Warm pine tones: main plank body, highlight grain, shadow gap -->
        <palette>
          <color>#C8915AFF</color>
          <color>#D9A870FF</color>
          <color>#A06830FF</color>
        </palette>
      </pattern>
    </Material>

    <!--
      Stone foundation is omitted for this slice: there is no Stone item asset
      and no harvestable that yields Stone, so a Stone foundation would stick in
      AwaitingMaterials forever (ConstructionSystem getDefNameId("Stone") == 0).
      Re-add the <Material name="Stone"> block once a Stone item asset and a
      Stone source (harvestable rock) exist. Wood works only because the
      material name "Wood" coincides with the Wood item defName.
    -->

  </Foundation>

  <!--
    Wall materials
    Each material offers discrete thickness presets (Light / Standard / Heavy).
    Wall work is computed as: length × thicknessMeters × workRatePerSquareMeter × workMultiplier
    Wall cost:               length × thicknessMeters × costRatePerSquareMeter × costMultiplier
    Wall HP:                 length × thicknessMeters × hp × hpMultiplier
    The per-area rates (costRatePerSquareMeter etc.) come from the Foundation block above
    for materials that appear in both sections. The merger happens at load time.

    NOTE: All preset values are starter estimates pending design tuning. See open question
    #2 in building-construction.md for the haul-logistics dependency that affects cost rates.
  -->
  <Wall>

    <!--
      Wood walls: studs + planking construction, fast to build, weak against fire.
      Wood is the only wall material here because it is the only material with a
      corresponding item asset and a harvestable source (palm/timber trees). Do not
      add Stone here until a Stone item + harvestable rock source exist.
    -->
    <Material name="Wood">
      <!--
        Thickness presets — starter values pending design tuning.
        Light  (~single-stud frame):      0.15 m, lower HP, fastest to build
        Standard (~double-stud frame):    0.20 m, balanced
        Heavy    (~log-wall / cob-style): 0.30 m, highest HP and insulation, slower build
      -->
      <Preset name="Light">
        <thicknessMeters>0.15</thicknessMeters>
        <costMultiplier>0.75</costMultiplier>
        <workMultiplier>0.75</workMultiplier>
        <hpMultiplier>0.75</hpMultiplier>
        <!-- Low thermal mass; thin wall lets heat through easily -->
        <insulation>0.2</insulation>
      </Preset>

      <Preset name="Standard">
        <thicknessMeters>0.20</thicknessMeters>
        <costMultiplier>1.0</costMultiplier>
        <workMultiplier>1.0</workMultiplier>
        <hpMultiplier>1.0</hpMultiplier>
        <!-- Moderate insulation: double-stud cavity traps some air -->
        <insulation>0.4</insulation>
      </Preset>

      <Preset name="Heavy">
        <thicknessMeters>0.30</thicknessMeters>
        <costMultiplier>1.5</costMultiplier>
        <workMultiplier>1.5</workMultiplier>
        <hpMultiplier>1.4</hpMultiplier>
        <!-- Dense timber / log construction, better thermal resistance -->
        <insulation>0.6</insulation>
      </Preset>
    </Material>

  </Wall>

  <!--
    Openings (doors / windows)
    An opening is carved into an existing wall segment. Unlike walls and
    foundations, opening cost and work are CONSTANTS per type, not area-derived:
    a door is a door regardless of the wall it sits in. material references a
    real <Foundation>/<Wall> material (Wood here; Stone omitted for the same
    reason walls omit it — no item asset / source). pathable says whether
    colonists can walk through the finished opening (doors yes, windows no).

    NOTE: All values are starter estimates pending design tuning.
      widthMeters - clear width of the opening along the wall centerline
      costItems   - fixed material items consumed to build the opening
      workUnits   - fixed work units to build (drives build time), per type
  -->
  <Opening>

    <Type name="Door">
      <material>Wood</material>
      <!-- 0.9 m clear width: a standard single-leaf doorway a colonist walks through. -->
      <widthMeters>0.9</widthMeters>
      <pathable>true</pathable>
      <!-- A door leaf + frame: a few planks, a modest constant build. -->
      <costItems>3.0</costItems>
      <workUnits>60.0</workUnits>
    </Type>

    <Type name="Window">
      <material>Wood</material>
      <!-- 0.6 m clear width: narrower than a door; light, not passage. -->
      <widthMeters>0.6</widthMeters>
      <pathable>false</pathable>
      <!-- Cheaper and quicker than a door: a frame and sash, no leaf. -->
      <costItems>2.0</costItems>
      <workUnits>40.0</workUnits>
    </Type>

  </Opening>

</ConstructionMaterials>
